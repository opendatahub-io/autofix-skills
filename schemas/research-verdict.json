{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Verdict",
  "description": "Verdict output from autofix-research skill.",
  "type": "object",
  "required": [
    "verdict",
    "summary"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "research"
      ]
    },
    "summary": {
      "type": "string"
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "upstream_consideration": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
