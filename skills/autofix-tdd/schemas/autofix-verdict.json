{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Autofix Verdict",
  "description": "Verdict output from autofix-resolve implement agent.",
  "type": "object",
  "required": [
    "verdict",
    "summary"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "committed",
        "already_fixed",
        "not_a_bug",
        "insufficient_info",
        "blocked",
        "ci_blocked",
        "no_changes"
      ]
    },
    "reason": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "self_review_issues_found": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "self_review_issues_fixed": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "lint_passed": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "build_passed": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "tests_passed": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "upstream_consideration": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "change_title": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "change_description": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
