{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Findings",
  "description": "Array of findings from the review agent.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "severity",
      "description",
      "file",
      "line"
    ],
    "properties": {
      "severity": {
        "type": "string",
        "enum": [
          "critical",
          "major",
          "minor",
          "nitpick"
        ]
      },
      "description": {
        "type": "string"
      },
      "file": {
        "type": "string"
      },
      "line": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
